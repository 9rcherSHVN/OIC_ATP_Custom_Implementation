%%{
  init: {
    "sequence": {
      "mirrorActors": false,
      "wrap": true,
      "noteMargin": 8
    },
    "theme": "default"
  }
}%%

sequenceDiagram
    autonumber

    %% ── Participants (ordered left → right by pipeline stage) ──────────────
    participant SCHED as OIC Scheduler
    participant F1    as F1 - DATA_EXTR
    participant EAM   as EAM REST API
    participant ATP   as Oracle ATP DB
    participant BUS   as AppEvent Bus
    participant F2    as F2 - BATC_PROC
    participant F3    as F3 - STAG_DATA_LOA
    participant F4    as F4 - VALID_INTEG
    participant BIP   as BIP SOAP
    participant F5    as F5 - IMPORT_INTEGR
    participant ERP   as ERP Cloud
    participant F6    as F6 - IMPOR_CALLB
    participant F7    as F7 - EAM_WRITEBACK

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 1 — DATA EXTRACTION
    %% Flow: UPDA_IFP_EAM_PO_RECE_DATA_EXTR_I | 01.00.0000
    %% Trigger: OIC Scheduler (scheduleReceive)
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(220, 235, 255)
        Note over SCHED,F1: PHASE 1 — Data Extraction  ·  F1: UPDA_IFP_EAM_PO_RECE_DATA_EXTR_I
        SCHED->>F1: scheduleReceive
        activate F1
        Note right of F1: Tracking: startTime (primary)<br/>Assignments a0–a31 (cursor vars per grid)<br/>ACTIVITY_STREAM_LOGGER lg0

        Note over F1,ATP: ── try t2 HeaderReceiveExtractGrid ──────────────────────
        loop WHILE hasMore pages
            F1->>EAM: FetchReceiveGridDetails (REST1) — paginated
            EAM-->>F1: receive header rows
            F1->>ATP: EAMReceiveHdrInsert (ATP1)
            ATP-->>F1: OK
            F1->>F1: advance cursor
        end

        Note over F1,ATP: ── try t4 LineReceiveExtractGrid ─────────────────────────
        loop WHILE hasMore pages
            F1->>EAM: FetchReceiveLineGridDetails (REST2) — paginated
            EAM-->>F1: receive line rows
            F1->>ATP: EAMRecieveLineInsert (ATP2)
            ATP-->>F1: OK
            Note right of ATP: [DEFECT] ATP proc name misspelled: EAMRecieve...
        end

        Note over F1,ATP: ── try t6 HeaderReturnExtractGrid ────────────────────────
        loop WHILE hasMore pages
            F1->>EAM: FetchRtnHdrGridDetails (REST3) — paginated
            EAM-->>F1: return header rows
            F1->>ATP: EAMReturnHdrInsert (ATP3)
            ATP-->>F1: OK
        end

        Note over F1,ATP: ── try t8 LineReturnExtractGrid ──────────────────────────
        loop WHILE hasMore pages
            F1->>EAM: FetchRtnLineGridDetails (REST4) — paginated
            EAM-->>F1: return line rows
            F1->>ATP: EAMReturnLineInsert (ATP4)
            ATP-->>F1: OK
        end

        Note over F1,ATP: ── try t10 RecptServiceExtraGrid ────────────────────────
        loop WHILE hasMore pages
            F1->>EAM: fetchServiceRecReturnGrid (REST5) — paginated
            EAM-->>F1: service receipt rows
            F1->>F1: Assignment a26
            F1->>ATP: InsertServiceStageloaddata (ATP5)
            ATP-->>F1: OK
        end

        Note over F1,ATP: ── try t1 PORCPTbatchCreation ── runs AFTER all 5 grids ──
        F1->>ATP: Insertintoextractloadtable (ATP6)
        ATP-->>F1: OK
        F1->>ATP: poRcptinboundbatchupdcre (ATP7)
        ATP-->>F1: BATCH_ID

        Note over F1,BUS: ── try t3 callprioritywise ──────────────────────────────
        F1->>ATP: PORCPTprior (ATP8)
        ATP-->>F1: priority value
        F1->>F1: Assign BatchID + Priority (a24,a25) · STITCH sh0 · XSLT
        F1->>BUS: PUBLISH CALLPRIORITYWISEPORCPT {batchId, priority}
        deactivate F1
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 2 — BATCH DISPATCH
    %% Flow: IFP_EAM_PO_RECE_BATC_PROC_INTE | 01.00.0000
    %% Trigger: SUBSCRIBE AppEvent CALLPRIORITYWISEPORCPT
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(220, 255, 220)
        Note over BUS,F3: PHASE 2 — Batch Dispatch  ·  F2: IFP_EAM_PO_RECE_BATC_PROC_INTE
        BUS->>F2: SUBSCRIBE CALLPRIORITYWISEPORCPT {batchId, priority}
        activate F2
        Note right of F2: Tracking: p_new_batch_id (primary)<br/>p_new_priority_col

        Note over F2,ATP: ── try t0 FetchPO_RCPTNewBatch ──────────────────────────
        F2->>ATP: BatchstatusDRAFTupd (ATP1) — batch status → DRAFT
        ATP-->>F2: OK
        F2->>F3: COLLOCATED callPORCPTstagedataloading {batchId}
        Note right of F2: [NOTE] CATCH_ALL ta0 → ehStop only, no ATP logging.<br/>Collocated chain failures terminate silently.
        deactivate F2
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 3 — STAGE DATA LOADING
    %% Flow: IFP_EAM_PO_RECEIPT_STAG_DATA_LOA | 01.00.0000
    %% Trigger: REST push via COLLOCATED from F2
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(255, 248, 220)
        Note over F2,F4: PHASE 3 — Stage Data Loading  ·  F3: IFP_EAM_PO_RECEIPT_STAG_DATA_LOA
        activate F3
        Note right of F3: Tracking: pbatchId (primary), poicintid<br/>Trigger: REST push-sync via COLLOCATED

        Note over F3,ATP: ── try t0 callbatchsplitting ────────────────────────────
        F3->>ATP: mainstageload (ATP1) — consolidate EAM grids → staging tables
        ATP-->>F3: staging complete
        F3->>ATP: updateReadybatchstatus (ATP2) — batch status → READY
        ATP-->>F3: OK
        F3->>F4: COLLOCATED CallChildPOValidationIntegration {batchId}
        Note right of F3: [NOTE] CATCH_ALL ta0 → ehStop only, no ATP logging.
        deactivate F3
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 4 — RECEIPT VALIDATION
    %% Flow: IFP_EAM_PO_RECEIPT_VALID_INTEG | 01.00.0000
    %% Trigger: REST push-sync (request-reply) via COLLOCATED from F3
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(255, 228, 228)
        Note over F3,F5: PHASE 4 — Receipt Validation  ·  F4: IFP_EAM_PO_RECEIPT_VALID_INTEG
        activate F4
        Note right of F4: [WARN] projectHasWarnings=true<br/>Trigger: REST push-sync — replies back to F3<br/>3 BIP reports fetched per BU (outer FOR loop)

        Note over F4,BIP: ── try t0 BIPreportcall ─────────────────────────────────
        F4->>ATP: fecthBUbatchlastrundetails (ATP1)
        ATP-->>F4: BU list + last-run timestamps
        Note right of ATP: [DEFECT] Proc name misspelled: fecth...

        loop FOR each Business Unit [f0]
            F4->>F4: Assignment a7 Setreportrundate

            Note over F4,BIP: try t3 BIPcallPOreceipt
            F4->>BIP: POreceiptreport · runReport  [labeled SOAP4 in flow XML]
            BIP-->>F4: PO receipt data (base64 XML)
            F4->>F4: XSLT m7 · stageFile sf3 write
            opt report has data [ROUTER s0/sc0]
                F4->>F4: stageFile sf6 segmented read
                F4->>ATP: POreceipt (ATP2)
                ATP-->>F4: OK
            end

            Note over F4,BIP: try t2 BIPcallSupplierReport
            F4->>BIP: BIPgetsupplierReport · runReport  [labeled SOAP2 in flow XML]
            BIP-->>F4: supplier reference data (base64 XML)
            F4->>F4: XSLT m6 · stageFile sf2 write
            opt report has data [ROUTER s1/sc1]
                F4->>F4: stageFile sf5 segmented read
                F4->>ATP: loadPOsupplierdet (ATP3)
                ATP-->>F4: OK
            end

            Note over F4,BIP: try t4 BIPCallinvItemReport
            F4->>BIP: BIPgetInvItemReport · runReport  [labeled SOAP4 in flow XML]
            BIP-->>F4: inventory item data (base64 XML)
            Note right of BIP: [DEFECT] POreceiptreport AND BIPgetInvItemReport<br/>both labeled 'SOAP4' — ambiguous in OIC monitor UI
            F4->>F4: XSLT m10 · stageFile sf4 write
            opt report has data [ROUTER s2/sc2]
                F4->>F4: stageFile sf7 segmented read
                F4->>ATP: loadInvItemdetailsrpt (ATP4)
                ATP-->>F4: OK
            end

            F4->>ATP: updatelastrundate (ATP5) — update BU last-run timestamp
            ATP-->>F4: OK
        end

        Note over F4,F5: ── try t5 POReceiptValidationScope ─────────────────────
        F4->>ATP: PORcptValidation (ATP6) — main validation stored proc
        ATP-->>F4: validation result
        opt IN-PROCESS status update needed [ROUTER s3/sc3]
            F4->>ATP: UpdateInprocessbatchstatus (ATP7) — batch status → IN-PROCESS
            ATP-->>F4: OK
        end
        F4->>F5: COLLOCATED CallChildImportInboundint {batchId}
        Note right of F4: [NOTE] CATCH_ALL ta3 → ehStop only, no notification.
        F4-->>F3: REPLY (push-sync response)
        deactivate F4
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 5 — FBDI IMPORT
    %% Flow: IFP_EAM_PO_IMPORT_INTEGR | 01.00.0000
    %% Trigger: REST push via COLLOCATED from F4
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(240, 228, 255)
        Note over F4,BUS: PHASE 5 — FBDI Import  ·  F5: IFP_EAM_PO_IMPORT_INTEGR
        activate F5
        Note right of F5: Trigger: REST push via COLLOCATED<br/>FBDI: header CSV + transaction CSV + properties + ZIP

        F5->>F5: Assignments a0–a7, a12
        F5->>ATP: getimportbatch (ATP1)
        ATP-->>F5: batch metadata

        Note over F5,ERP: ── try t0 POReceiptmainScope — ROUTER s0/sc0 ────────────
        F5->>ATP: FetchPOReceiptfbdidata (ATP2) — fetch FBDI-ready receipt rows
        ATP-->>F5: receipt records
        opt receipt header rows exist [ROUTER s1/sc1]
            F5->>F5: stageFile writeRcptHeaderFile (sf0)
        end
        F5->>F5: stageFile WriteRcptTrxFile (sf1) — receipt transaction CSV
        F5->>F5: stageFile writePropertiesFile (sf3) — FBDI properties file
        F5->>F5: stageFile createZipFile (sf2) — create FBDI ZIP archive
        F5->>F5: stageFile listZipFile (sf4) — list ZIP contents
        F5->>ERP: importRcptsToERP [importBulkData] — upload ZIP to ERP UCM + submit ESS job
        ERP-->>F5: ESS requestId
        F5->>F5: ACTIVITY_STREAM_LOGGER lg0
        F5->>ATP: updateBatchStatusProcedure (ATP3) — store ESS requestId in ATP
        ATP-->>F5: OK
        F5->>F5: Assignment a10 (load_request_id)

        Note over F5,ATP: ── try t1 ProcessedtrxReport — ROUTER s2/sc2 ────────────
        F5->>ATP: FetchPORCPTproecssdata (ATP4) — fetch processed receipt summary
        ATP-->>F5: processed receipt summary
        Note right of ATP: [DEFECT] Proc name misspelled: proecss...
        F5->>F5: Assign a11,a13 AssignStatus
        F5->>F5: stageFile writeporcptprocesscolumn (sf5)
        F5->>F5: stageFile WritePORCPTprocessdata (sf6)
        F5->>F5: notification email (n1)
        F5->>F5: ACTIVITY_STREAM_LOGGER lg1
        F5->>BUS: PUBLISH UPDATEERRORINEAMHEXAGON {batchId}
        Note right of F5: Fire-and-forget → F7 subscribes and processes.<br/>F5 does NOT wait for EAM writeback to complete.
        deactivate F5
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 6 — ERP IMPORT CALLBACK
    %% Flow: IFP_PO_RECEI_IMPOR_CALLB_REQUE | 01.00.0000
    %% Trigger: ERP Cloud business event poimportorderscallback (async, ESS completion)
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(255, 243, 200)
        Note over ERP,F6: PHASE 6 — ERP Import Callback  ·  F6: IFP_PO_RECEI_IMPOR_CALLB_REQUE
        ERP->>F6: poimportorderscallback onEvent [ERPInteg_Import_Completed]
        activate F6
        Note right of F6: [WARN] projectHasWarnings=true<br/>Tracking: DOCUMENTID primary (ESS requestId)<br/>XPath: /onEvent/ErpImportBulkDataEvent/DOCUMENTID
        Note right of F6: [RISK] Async gap: if ERP ESS job fails silently,<br/>poimportorderscallback never fires.<br/>Batch stuck in INPROCESS — no OIC watchdog.

        F6->>F6: STITCH sh2 · global vars gtv0–gtv6
        F6->>F6: stageFile writerequestidfilercpt (sf8) — write ESS requestId to stage file
        F6->>F6: Assignments a0–a4

        Note over F6,BUS: ── try t0 ScopePrioritywisebatch — chain-fire logic ──────
        F6->>ATP: getprioritywisenextbatch (ATP1)
        ATP-->>F6: next queued batch (if any)
        alt next priority batch queued [ROUTER s5/sc6]
            F6->>BUS: PUBLISH CALLPRIORITYWISEPORCPT {nextBatchId, priority}
            Note right of BUS: Chain-fire: F2 begins next batch concurrently<br/>while F6 continues processing current batch.
        else no more batches [sc7]
            F6->>F6: ACTIVITY_STREAM_LOGGER lg0
        end

        Note over F6,ATP: ── try t1 MainScope — 3-route ROUTER s0 ────────────────
        alt Route sc0 — standard import results (SUMMARYSTATUS = 0)
            F6->>ATP: updateimportrequestid (ATP2)
            ATP-->>F6: OK
            F6->>F6: STITCH sh0
            F6->>BIP: callBIPReport · runReport (SOAP1)
            BIP-->>F6: error summary report (base64 XML)
            F6->>F6: stageFile sf0 writestagefile · XSLT
            opt error rows in report [ROUTER s1/sc2]
                F6->>F6: stageFile sf2 segmented read
                F6->>ATP: insertpoerroratp (ATP4)
                ATP-->>F6: OK
                F6->>ATP: POerrordetailsrpt (ATP6)
                ATP-->>F6: OK
            end
            F6->>BIP: callImportDetailsReport · runReport (SOAP3)
            BIP-->>F6: import detail report (base64 XML)
            F6->>F6: stageFile sf4 write · XSLT
            opt detail rows in report [ROUTER s3/sc4]
                F6->>F6: stageFile sf6 segmented read
                F6->>ATP: insertImportDetailsintoATPDB (ATP8)
                ATP-->>F6: OK
                F6->>ATP: callImportDetailsProcedure (ATP9)
                ATP-->>F6: OK
            end

        else Route sc1 — extended error report (SUMMARYSTATUS = 1)
            F6->>ATP: updateimportrequestid (ATP3)
            ATP-->>F6: OK
            F6->>F6: STITCH sh1
            F6->>BIP: callErrorReport · runReport (SOAP2)
            BIP-->>F6: extended error report (base64 XML)
            F6->>F6: stageFile sf1 write · XSLT
            opt error rows in report [ROUTER s2/sc3]
                F6->>F6: stageFile sf3 segmented read
                F6->>ATP: insertImportDetailsError (ATP10)
                ATP-->>F6: OK
                F6->>ATP: callImportDetailsErrorProcedure (ATP11)
                ATP-->>F6: OK
            end
            F6->>BIP: SOAP4 · runReport (import detail — error variant)
            BIP-->>F6: error detail report (base64 XML)
            F6->>F6: stageFile sf5 write · XSLT
            opt detail rows in report [ROUTER s4/sc5]
                F6->>F6: stageFile sf7 segmented read
                F6->>ATP: insertImportDetailsintoATPDB (ATP5)
                ATP-->>F6: OK
                F6->>ATP: POerrordetailsrpt (ATP7)
                ATP-->>F6: OK
            end

        else Route sc8 — ESS status-only / no processable report
            F6->>ERP: DonloadZIPFile (ERP Cloud2)
            ERP-->>F6: ESS ZIP log
            Note right of ERP: [DEFECT] ERP adapter op name: 'DonloadZIPFile' — typo
            F6->>F6: stageFile sf11 WriteERPLog
            F6->>F6: notification n1
        end

        Note over F6,ATP: ── try t2 ProcessedtrxReport ────────────────────────────
        F6->>ATP: FetchPORcptproecssdata (ATP12)
        ATP-->>F6: processed receipt summary
        Note right of ATP: [DEFECT] Proc name misspelled: proecss...
        F6->>F6: stageFile sf9 writeporcptprocesscolumn
        F6->>F6: stageFile sf10 WritePORCPTprocessdata
        F6->>F6: notification email (n2)
        F6->>BUS: PUBLISH UPDATEERRORINEAMHEXAGON {batchId}
        Note right of F6: [RISK] F5 AND F6 both publish UPDATEERRORINEAMHEXAGON<br/>for same batchId. Two concurrent F7 instances may<br/>run without mutex guard in ATP query procedures.
        deactivate F6
    end

    %% ══════════════════════════════════════════════════════════════════════
    %% PHASE 7 — EAM WRITEBACK
    %% Flow: IFP_EAM_UPDA_MESS_IN_EAM_HEXA | 01.00.0000
    %% Trigger: SUBSCRIBE AppEvent UPDATEERRORINEAMHEXAGON
    %% Publishers: F5, F6, IMPOR_CALLB_REPRO, UPDA_MESS_EAM_HEXA_RE
    %% ══════════════════════════════════════════════════════════════════════
    rect rgb(220, 255, 240)
        Note over BUS,EAM: PHASE 7 — EAM Writeback  ·  F7: IFP_EAM_UPDA_MESS_IN_EAM_HEXA
        BUS->>F7: SUBSCRIBE UPDATEERRORINEAMHEXAGON {batchId}
        activate F7
        Note right of F7: Flat orchestration (no globalTry).<br/>SUCCESS scope (try t1) executes BEFORE error scope (try t0).<br/>2 success paths: Purchase Receipt vs Service Receipt.

        Note over F7,EAM: ── try t1 UpdateSuccessEAM (runs FIRST) ────────────────
        F7->>F7: Assign lv_successBatchId, org, tenant (a2,a3,a4)
        F7->>ATP: GetSuccessPORcpt (ATP1)
        ATP-->>F7: list of successfully imported receipts
        opt success records exist [ROUTER s1/sc1]
            loop FOR each success record [f2] — try t3 SwitchLogicForServices
                alt Purchase Receipt [ROUTER s3/sc3]
                    F7->>EAM: UpdateEAMPOReceiptSuccessStatus (REST4)
                    EAM-->>F7: OK
                    F7->>ATP: SentEAMUpdateinDB (ATP4) — record sent flag
                    ATP-->>F7: OK
                else Service Receipt [ROUTER s3/sc4]
                    F7->>EAM: ServiceReceiptUpdate (REST5)
                    EAM-->>F7: OK
                    F7->>ATP: SentUpdateEAMinDB (ATP5) — record sent flag
                    ATP-->>F7: OK
                end
            end
        end

        Note over F7,EAM: ── try t0 UpdateEAMError (runs SECOND) ─────────────────
        F7->>F7: Assign org, tenant (a0,a1)
        F7->>ATP: GetPOReceiptErrorRecords (ATP2)
        ATP-->>F7: list of error header records
        opt error records exist [ROUTER s0/sc0]
            loop FOR each error header [f0] — ROUTER s2/sc2 — try t4 EAMHeaderErrorAPIScope
                F7->>EAM: UpdateEAMPOReceiptStatus (REST3) — set overall PO receipt status to ERROR
                EAM-->>F7: OK
                F7->>EAM: EAMHeaderErrorAPI (REST1) — push header error detail
                EAM-->>F7: OK
                F7->>ATP: StatusUpdationEAM (ATP7) — record header error status
                ATP-->>F7: OK
                F7->>ATP: GetPOReceiptLineErrors (ATP3) — fetch line errors for this header
                ATP-->>F7: error line records
                loop FOR each error line [f1] — try t2 EAMLineErrorLogsAPI
                    F7->>EAM: EAMLineErrorAPI (REST2) — push line error detail
                    EAM-->>F7: OK
                    F7->>ATP: UpdateEAMStatus (ATP6) — record line error status
                    ATP-->>F7: OK
                end
            end
        end
        deactivate F7
    end
