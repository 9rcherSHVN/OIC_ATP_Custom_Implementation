%%  Tier 1 — Master Overview Topology
%%  IFP_PO_INBOUN_INTEGR_ATP  |  8 Integration Flows
%%  Rendering: Mermaid v10.9+  |  flowchart LR

flowchart LR
    subgraph EXT ["External Systems"]
        direction TB
        EAM["EAM System\n(REST / BASIC_AUTH)"]
        ERP["Oracle ERP Cloud\n(ERP Adapter + REST)"]
        BIP["Oracle BIP SOAP\n(SOAP / UsernameToken)"]
    end

    subgraph PLATFORM ["OIC Platform"]
        direction TB
        ATP["Oracle ATP DB\n(JDBC_OVER_SSL)"]
        AppEvt(["OIC App Event Bus"])
        Sched(["OIC Scheduler\n15 min · Asia/Calcutta"])
    end

    subgraph FLOWS ["OIC Integration Flows"]
        direction TB
        subgraph PH1 ["Phase 1 · Extract"]
            F1["F1 · DATA_EXTRA\nIFP_EAM_PO_DATA_EXTRA_INTEG"]
        end
        subgraph PH2 ["Phase 2 · Dispatch"]
            F2["F2 · BATCH_PROCE\nIFP_EAM_PO_BATCH_PROCE_INTEG"]
        end
        subgraph PH3 ["Phase 3 · Stage Load"]
            F3["F3 · STAG_DATA_LOAD\nIFP_EAM_PO_STAG_DATA_LOAD_INTE"]
        end
        subgraph PH4 ["Phase 4 · Validate"]
            F4["F4 · VALIDA\nIFP_EAM_PO_VALIDA_INTEGR"]
        end
        subgraph PH5 ["Phase 5 · Import"]
            F5["F5 · IMPORT\nIFP_EAM_PO_IMPORT_INTEGR"]
        end
        subgraph PH6 ["Phase 6 · Callback"]
            F6["F6 · IMPOR_CALLB\nIFP_PO_IMPOR_CALLB_16_FEB"]
        end
        subgraph PH7 ["Phase 7 · Writeback"]
            F7["F7 · STATUS_EVENT\nIFP_EAM_STATUS_EVENT_INTEGR"]
            F8["F8 · STATU_UPDAT\nIFP_EAM_STATU_UPDAT_INTEG_M"]
        end
    end

    %% --- Trigger edges ---
    Sched      -- "Schedule\n(every 15 min)" --> F1
    ERP        -- "ERP Cloud business event\npoimportorderscallback" --> F6

    %% --- AppEvent edges ---
    F1         -- "PUBLISH\nTRIGGERNEWPOBATCH\n(fire-and-forget)" --> AppEvt
    AppEvt     -- "SUBSCRIBE\nTRIGGERNEWPOBATCH" --> F2

    F5         -- "PUBLISH\nPUBLISH_EAMPOSTATUSUPDAT\n(SUBMITTED)" --> AppEvt
    F6         -- "PUBLISH\nPUBLISH_EAMPOSTATUSUPDAT\n(COMPLETE/ERROR)" --> AppEvt
    AppEvt     -- "SUBSCRIBE\nPUBLISH_EAMPOSTATUSUPDAT\n(fires twice per batch)" --> F7

    %% --- Collocated (synchronous) invocation chain ---
    F2         -- "COLLOCATED\nInvokePOStageloadintegration" --> F3
    F3         -- "COLLOCATED\nCallChildPOValidationIntegration" --> F4
    F4         -- "COLLOCATED\nCallChildImportInboundint" --> F5
    F7         -- "COLLOCATED\nCallPOEAMUpdateStatusIntegration" --> F8

    %% --- External system interactions (summarised) ---
    F1         -- "REST GET\nFetchHdrGridDetails\nFetchLineGridDetails" --> EAM
    F1         -- "ATP writes\nbatch + grid staging" --> ATP
    F2         -- "ATP read/write\nponewbatchfetch\nupdatebatchstatusasDraft" --> ATP
    F3         -- "ATP write\nmainstageload" --> ATP
    F4         -- "SOAP calls\n5 BIP reports" --> BIP
    F4         -- "ATP load\nreference data" --> ATP
    F4         -- "ERP API\nCreateMasterItems\nCreateChildItemOrg" --> ERP
    F5         -- "ERP REST\nGetBUID / GETBUYER" --> ERP
    F5         -- "ERP Adapter\nFBDI UCM upload\nESS job submit" --> ERP
    F5         -- "ATP writes\ntransfer status\nessRequestId" --> ATP
    F6         -- "SOAP calls\ncallBIPReport\ncallErrorReport\ncallImportDetailsReport\ncallImportDetailsErrorReport" --> BIP
    F6         -- "ATP writes\nimport results\nerror records" --> ATP
    F8         -- "REST PUT\nUpdateEAMPOSuccessStatus\nEAMcallHdrErrorAPI\nEAMCallLineErrorAPI\nUpdateCancelLineStatus" --> EAM
    F8         -- "ATP read/write\nGetSuccessPOs\ngetPOerrorrecords\nSentEAMUpdate" --> ATP

    %% --- Styling ---
    classDef flow fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef ext  fill:#fef3c7,stroke:#d97706,color:#78350f
    classDef plat fill:#d1fae5,stroke:#059669,color:#064e3b
    classDef evt  fill:#ede9fe,stroke:#7c3aed,color:#3b0764

    class F1,F2,F3,F4,F5,F6,F7,F8 flow
    class EAM,ERP,BIP ext
    class ATP,Sched,AppEvt plat
